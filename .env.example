# ============================================================================
# ZephyrPay — Environment Variables
# Copy to .env.local (app) and .env (contracts) and fill in real values.
# ============================================================================

# ---- HashKey Chain ---------------------------------------------------------
HASHKEY_TESTNET_RPC="https://testnet.hsk.xyz"
HASHKEY_TESTNET_CHAIN_ID=133
HASHKEY_TESTNET_EXPLORER="https://testnet-explorer.hsk.xyz"
HASHKEY_TESTNET_EXPLORER_API="https://testnet-explorer.hsk.xyz/api"

HASHKEY_MAINNET_RPC="https://mainnet.hsk.xyz"
HASHKEY_MAINNET_CHAIN_ID=177

# Block explorer API key (for contract verification); may be empty for Blockscout
HASHKEY_EXPLORER_API_KEY=""

# ---- Deployer / Attestor Keys ---------------------------------------------
# Deployer key: must be funded on HashKey testnet. NEVER commit real keys.
DEPLOYER_PRIVATE_KEY=""

# Attestor key: signs EIP-712 PoH attestations off-chain, verified on-chain.
# In production this lives in a KMS / HSM. Locally this is an env var.
ATTESTOR_PRIVATE_KEY=""
ATTESTOR_ADDRESS=""

# Scorer key: signs EIP-712 credit-score attestations.
SCORER_PRIVATE_KEY=""
SCORER_ADDRESS=""

# ---- Deployed Contract Addresses (populated after first deploy) -----------
NEXT_PUBLIC_HKDM_ADDRESS=""
NEXT_PUBLIC_POH_REGISTRY_ADDRESS=""
NEXT_PUBLIC_CREDIT_LINE_ADDRESS=""
NEXT_PUBLIC_CHAIN_ID=133

# ---- DeepSeek (AI scoring) -------------------------------------------------
# Get a key at https://platform.deepseek.com/api_keys
# Models: "deepseek-chat" (V3, fast, cheap) or "deepseek-reasoner" (R1, slower).
# Use deepseek-chat for credit scoring — temperature 0, JSON mode, ~1-3s p50.
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# ---- WalletConnect / RainbowKit -------------------------------------------
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# ---- HashKey HP2 (Payment Protocol v2) Single-Pay ------------------------
# Register a merchant at https://merchant-qa.hashkeymerchant.com to obtain
# app_key / app_secret. The merchant_private_key is a secp256k1 PEM you
# generate yourself and submit the corresponding public key to HP2 ops.
#
# Generate the keypair:
#   openssl ecparam -name secp256k1 -genkey -noout -out merchant_private.pem
#   openssl ec -in merchant_private.pem -pubout -out merchant_public.pem
#
# Embed the PEM multi-line value into the env var by replacing newlines
# with \n in the value below.
HP2_BASE_URL="https://merchant-qa.hashkeymerchant.com"
HP2_APP_KEY=""
HP2_APP_SECRET=""
HP2_MERCHANT_NAME="ZephyrPay"
HP2_MERCHANT_PRIVATE_KEY=""
# Separate webhook secret is optional — defaults to HP2_APP_SECRET.
HP2_WEBHOOK_APP_SECRET=""
# USDC on HashKey Chain testnet receiving address (your merchant wallet).
HP2_PAY_TO=""

# ---- Settlement relayer (auto-repay on payment confirm) ------------------
# Private key holding SETTLEMENT_ROLE on the deployed CreditLine. When an
# HP2 payment confirms, the /api/webhooks/hp2 route uses this key to call
# CreditLine.onSaleReceived(borrower, amount) on HashKey Chain, paying down
# the merchant's loan automatically.
SETTLEMENT_RELAYER_PRIVATE_KEY=""

# ---- Rate limiting --------------------------------------------------------
# Upstash Redis for API rate limiting (optional — falls back to in-memory)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
